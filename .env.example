# ── API Security ────────────────────────────────────────
# Set a secret key to protect the endpoint.
# Leave blank to disable authentication.
API_KEY=your_secret_api_key_here

# ── Tesseract OCR (Windows only) ─────────────────────────
# Default path after installing from https://github.com/UB-Mannheim/tesseract/wiki
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── CORS (optional) ──────────────────────────────────────
# Comma-separated allowed origins for the frontend.
# Use * to allow all (development only).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500
